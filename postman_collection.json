  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Get Keycloak Token",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.sendRequest({",
                  "    url: pm.variables.get('keycloakUrl') + '/realms/' + pm.variables.get('keycloakRealm') + '/protocol/openid-connect/token',",
                  "    method: 'POST',",
                  "    header: {",
                  "        'Content-Type': 'application/x-www-form-urlencoded'",
                  "    },",
                  "    body: {",
                  "        mode: 'urlencoded',",
                  "        urlencoded: [",
                  "            { key: 'client_id', value: pm.variables.get('keycloakClientId') },",
                  "            { key: 'grant_type', value: 'password' },",
                  "            { key: 'username', value: pm.variables.get('keycloakUsername') },",
                  "            { key: 'password', value: pm.variables.get('keycloakPassword') }",
                  "        ]",
                  "    }",
                  "}, function (err, res) {",
                  "    if (err) {",
                  "        console.log(err);",
                  "    } else {",
                  "        var jsonData = res.json();",
                  "        pm.variables.set('authToken', 'Bearer ' + jsonData.access_token);",
                  "        console.log('Token obtained successfully');",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded",
                "type": "text"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "client_id",
                  "value": "{{keycloakClientId}}",
                  "type": "text"
                },
                {
                  "key": "grant_type",
                  "value": "password",
                  "type": "text"
                },
                {
                  "key": "username",
                  "value": "{{keycloakUsername}}",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "{{keycloakPassword}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{keycloakUrl}}/realms/{{keycloakRealm}}/protocol/openid-connect/token",
              "host": ["{{keycloakUrl}}"],
              "path": ["realms", "{{keycloakRealm}}", "protocol", "openid-connect", "token"]
            }
          },
          "response": []
        }
      ]
    },
